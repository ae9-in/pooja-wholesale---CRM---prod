# Production Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=production
PORT=5001

# Database
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/wholesale_crm?retryWrites=true&w=majority

# Cross-origin frontend URL
CORS_ORIGIN=https://your-frontend-project.vercel.app

# File Upload Configuration
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5
DEFAULT_OPERATOR_EMAIL=admin@wholesale.local
CRON_SECRET=replace-with-a-long-random-string
