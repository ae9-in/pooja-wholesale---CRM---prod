{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/internal/jobs/reminders/sync",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/internal/jobs/reminders/repair",
      "schedule": "0 */6 * * *"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}
