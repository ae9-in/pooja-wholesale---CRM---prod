{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": [
        "src/generated/prisma/**",
        "prisma/schema.prisma"
      ]
    }
  },
  "crons": [
    {
      "path": "/api/internal/jobs/reminders/maintenance",
      "schedule": "0 0 * * *"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}
